se,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false}},"citems":[{"id":"5rSRxtK4WPdVEW1f","ikey":"","name":"Zarpazo","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Zarpazo","daño_pnj":{"value":"1d4"},"da_pnj":{"value":"d6"}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey":"gr_ataquespnj"}],"usetype":"PAS","ispermanent":false,"rechargable":false,"maxuses":1,"uses":1,"icon":"BOOK","selfdestruct":false,"mods":[],"disabledmods":[]},{"id":"7JrGwdopsaxUCgKy","ikey":"","name":"Mordisco","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Mordisco","daño_pnj":{"value":"2d8"},"da_pnj":{"value":"d6"}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey":"gr_ataquespnj"}],"usetype":"PAS","ispermanent":false,"rechargable":false,"maxuses":1,"uses":1,"icon":"BOOK","selfdestruct":false,"mods":[],"disabledmods":[]},{"id":"oXQTHz8QtndQ7LnW","ikey":"","name":"Aliento venenoso","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Aliento venenoso","daño_pnj":{"value":"0"},"da_pnj":{"value":"1"}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey":"gr_ataquespnj"}],"usetype":"PAS","ispermanent":false,"rechargable":false,"maxuses":1,"uses":1,"icon":"BOOK","selfdestruct":false,"mods":[],"disabledmods":[]}],"rolls":{},"biography":""},"ownership":{"default":0,"jZrpyZWDeO9ZrFIz":3},"prototypeToken":{"flags":{},"name":"Guiverno","displayName":0,"width":1,"height":1,"lockRotation":false,"rotation":0,"actorLink":false,"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"randomImg":false,"alpha":1,"light":{"alpha":1,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"type":null,"reverse":false},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"texture":{"src":"worlds/tesoroyg