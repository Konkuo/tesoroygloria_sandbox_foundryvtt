"value":"1d8","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_actual_pnj":{"id":"3CRGe021z6heUyKW","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_totales_pnj":{"id":"I7saN3A1Pc6tP2JP","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"salvaciones_pnj":{"id":"muaKYz2kmzsl5Cbp","value":"Constitución","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"moral_pnj":{"id":"w9q5nM0h2aM1gAPs","value":"9","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"gloria_pnj":{"id":"GKgvhSguApjIemPx","value":"30","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"tesoro_pnj":{"id":"vWzdz8cpctB1J8AM","value":"Nada","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"notas_pnj":{"id":"1WHoLtjD4sE2zKVA","value":"Los infestados pueden hablar, aunque han perdido todo vestigio de humanidad y su dolor y locura hace que para ellos razonar sea casi imposible. Un personaje que sufra daño por el ataque de un infestado queda afligido por la Plaga a menos que supere una tirada de Carisma. La Plaga tiene un período de incubación de 1d4 días, tras los cuales el estado del personaje empeorará rápidamente a lo largo de 1d4 días más; larvas y moscas comienzan a emerger de su piel dejando horribles llagas infectadas y purulentas. La mayoría mueren pasados esos días, pero existe 1-2 en 1d6 posibilidades de que en su lugar se transforme en otro infestado. Se puede eliminar la Plaga antes de ese tiempo con una invocación de Vida o de Luz de nivel 2.\n\nLas moscas que acompañan a los infestados se ceban con las heridas de sus enemigos. Cualquier PJ que comience el asalto adyacente a un infestado y con la mitad de sus pg o menos, sufrirá automáticamente 1 punto de daño. Los personajes que lleven armas con la propiedad de Alcance no se verán afectados a menos que sean acorralados.","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false}},"citems":[{"id":"0SejbaGt6U9uYtEn","ikey":"","name":"Abalanzarse","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Abalanzarse","daño_pnj":{"value":"1d4"},"da_pnj":{"value":"d20"}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey":"gr_ataquespnj"}],"usetype":"PAS","ispermanent":false,"rechargable":false,"maxuses":1,"uses":1,"icon":"BOOK","selfdestruct":false,"mods":[],"disabledmods":[]}],"rolls":{},"biography":""},"ownership":{"default":0,"jZrpyZWDeO9ZrFIz":3},"prototypeToken":{"flags":{},"name":"Infestados","displayName":0,"width":1,"height":1,"lockRotation":false,"rotation":0,"actorLink":false,"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"randomImg":false,"alpha":1,"light":{"alpha":1,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"type":null,"reverse":false},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"texture":{"src":"worlds/tesoroygloria/resources/Recursos%20Compendium/Bestiario/icono_impios.png","tint":null,"scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"visionMode":"basic","color":null,"attenuation":0.1,"saturation":0,"contrast":0},"detectionModes":[]},"_stats":{"systemId":"sandbox","systemVersion":"0.14.4.4","coreVersion":"10.312","createdTime":null,"modifiedTime":1777448489728,"lastModifiedBy":"jZrpyZWDeO9ZrFIz"}}
