alue":"9d8+27","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_actual_pnj":{"id":"3CRGe021z6heUyKW","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_totales_pnj":{"id":"I7saN3A1Pc6tP2JP","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"salvaciones_pnj":{"id":"muaKYz2kmzsl5Cbp","value":"Fuerza, Constitución, Inteligencia","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"moral_pnj":{"id":"w9q5nM0h2aM1gAPs","value":"9","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"gloria_pnj":{"id":"GKgvhSguApjIemPx","value":"1600","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"tesoro_pnj":{"id":"vWzdz8cpctB1J8AM","value":"Monedas abundante - 2d8 x 100 mo\nGemas bastante - 1d20 gemas\nJoyas escaso - 1 joya\nObjetos precioso abundante - 1d8 obj.\nPillaje bastante - 1d120 mo","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"notas_pnj":{"id":"1WHoLtjD4sE2zKVA","value":"2 zarpazos y mordisco\nHay 1-2 en 1d6 posibilidades de que el trol anciano tenga +1d3 cabezas. Un trol que tenga varias cabezas no puede ser tomado por sorpresa, pero también es posible que las cabezas se lleven mal entre ellas y discutan. Si las cabezas están envueltas en una discusión, entonces sí es posible pillar desprevenido al trol, y además durante el próximo combate su iniciativa será siempre 2. Hay un 1-2 en 1d6 de posibilidades de que un trol anciano sea además un hechicero, con Dado de Hechicería d8 y Umbral de Poder 4. Conocerá 1d4 conjuros escogidos al azar de la siguiente lista y llevará preparados 1d4 de ellos:\n1.Polimorfar 2.Invisibilidad 3.Agua 4.Piedra 5.Ilusión 6.Sueño 7.Orden 8.Protección mágica","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false}},"citems":[{"id":"5rSRxtK4WPdVEW1f","ikey":"","name":"Zarpazo","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Zarpazo","daño_pnj":{"value":"1d8"},"da_pnj":{"value":"d4"}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey":"gr_ataquespnj"}],"usetype":"PAS","ispermanent":false,"rechargable":false,"maxuses":1,"uses":1,"icon":"BOOK","selfdestruct":false,"mods":[],"disabledmods":[]},{"id":"7JrGwdopsaxUCgKy","ikey":"","name":"Mordisco","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Mordisco","daño_pnj":{"value":"2d6"},"da_pnj":{"value":"d4"}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey":"gr_ataquespnj"}],"usetype":"PAS","ispermanent":false,"rechargable":false,"maxuses":1,"uses":1,"icon":"BOOK","selfdestruct":false,"mods":[],"disabledmods":[]}],"rolls":{},"biography":""},"ownership":{"default":0,"jZrpyZWDeO9ZrFIz":3},"prototypeToken":{"flags":{},"name":"Trol","displayName":0,"width":1,"height":1,"lockRotation":false,"rotation":0,"actorLink":false,"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"randomImg":false,"alpha":1,"light":{"alpha":1,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"type":null,"reverse":false},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"texture":{"src":"worlds/tesoroygloria/resources/Recursos%20Compendium/Bestiario/icono_gigantes.png","tint":null,"scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"visionMode":"basic","color":null,"attenuation":0.1,"saturation":0,"contrast":0},"detectionModes":[]},"_stats":{"systemId":"sandb