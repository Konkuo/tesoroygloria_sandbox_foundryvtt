0d8+30","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_actual_pnj":{"id":"3CRGe021z6heUyKW","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_totales_pnj":{"id":"I7saN3A1Pc6tP2JP","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"salvaciones_pnj":{"id":"muaKYz2kmzsl5Cbp","value":"Fuerza, Constitución, Inteligencia, Sabiduría, Carisma","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"moral_pnj":{"id":"w9q5nM0h2aM1gAPs","value":"9","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"gloria_pnj":{"id":"GKgvhSguApjIemPx","value":"2500","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"tesoro_pnj":{"id":"vWzdz8cpctB1J8AM","value":"Monedas abundante - 2d8 x 100 mo\nGemas bastante - 1d20 gemas\nJoyas bastante - 1d4 joyas\nPillaje abundante - 2d100 mo","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"notas_pnj":{"id":"1WHoLtjD4sE2zKVA","value":"Reacción: Para concretar su reacción tira 1d4: 1 = -1 | 2 = +1 | 3 = -2 y además el gigante está loco | 4 = +2\n\nLos erraldos poseen un Dado de Hechicería d8, UP 5 y conocen 1d8 conjuros de la siguiente lista, de los cuales llevan preparados 1d4+1: \n1.Polimorfar 2.Levitación 3. Invisibilidad 4. Hechizar 5. Memoria 6. Desterrar 7. Rayo 8. Piedra 9. Escarcha 10.Visión 11. Ilusión 12. Protección mágica\n\nCuando un erraldo ataca, puede elegir recibir un penalizador de DA +1 para realizar un barrido, enfrentando su tirada de ataque con la CA de todos los enemigos situados en un área. Cualquiera que reciba daño crítico de un erraldo tendrá que superar una tarea difícil de Acrobacias o Potencia, o salir volando 1d10 metros en una dirección aleatoria, recibiendo 1d6 puntos de daño por cada 2 metros de distancia que haya volado.","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false}},"citems":[{"id":"c4aTElI2cpyUQMUc","ikey":"","name":"Garrotazo","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Garrotazo","daño_pnj":{"value":"3d8"},"da_pnj":{"value":"d4"}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey":"gr_ataquespnj"}],"usetype":"PAS","ispermanent":false,"rechargable":false,"maxuses":1,"uses":1,"icon":"BOOK","selfdestruct":false,"mods":[],"disabledmods":[]}],"rolls":{},"biography":""},"ownership":{"default":0,"jZrpyZWDeO9ZrFIz":3},"prototypeToken":{"flags":{},"name":"Erraldo","displayName":0,"width":1,"height":1,"lockRotation":false,"rotation":0,"actorLink":false,"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"randomImg":false,"alpha":1,"light":{"alpha":1,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"type":null,"reverse":false},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"texture":{"src":"worlds/tesoroygloria/resources/Recursos%20Compendium/Bestiario/icono_gigantes.png","tint":null,"scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"visionMode":"basic","color":null,"attenuation":0.1,"saturation":0,"contrast":0},"detectionModes":[]},"_stats":{"systemId":"sandbox","systemVersion":"0.14.4.4","coreVersion":"10.312","createdTime":null,"modifiedTime":1777448489090,"lastModifiedBy":"jZrpyZWDeO9ZrFIz"}}
