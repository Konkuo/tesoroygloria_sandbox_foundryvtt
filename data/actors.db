{"_id":"W4msQWHNjhoW1IH1","name":"Replicante","type":"character","img":"worlds/tesoroygloria/resources/Recursos%20Compendium/Bestiario/icono_informes.png","items":[],"effects":[],"folder":"b82ChDPJ0CLMxRRI","sort":400001,"flags":{"sbupdated":0,"ischeckingauto":false,"hasupdated":true,"scrolls":{"jZrpyZWDeO9ZrFIz":0},"lastupdatedBy":"jZrpyZWDeO9ZrFIz","activetab":0,"selectedtab":0,"haschanged":true,"sandbox":{"originalId":"W4msQWHNjhoW1IH1"}},"system":{"tabs":[],"istemplate":false,"gtemplate":"TyG_PNJ 1.0","sheets":["Default","TyG_PJ 1.0","TyG_PNJ 1.0"],"mod":"0","rollmode":"1d20","displayName":0,"tokenbar1":"attributes.","shieldstat":"","biovisible":true,"visitabs":3,"_html":"","backg":"","resizable":true,"setheight":600,"setwidth":650,"buildlog":"","selector":false,"attributes":{"tipo_pnj":{"id":"TPYqCw48wviNzZ5z","value":"Informe","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"vacia01":{"id":"V7x0LLDlex8CYwlq","value":"","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"numero_encuentro":{"id":"gbjg7FGebCEXoLCT","value":"1d10","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"numero_guarida":{"id":"LfO1EyAy2B6cWxrs","value":"2d10","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"reaccion":{"id":"xVWTk4TP21qu0C73","value":"Hostil","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"vel_pnj":{"id":"qNsaYmedjmMtwhnK","value":"10 m","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"ca_pnj":{"id":"cjj9fPKtXeZegxyg","value":8,"prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"max":null,"modified":false,"modmax":false},"dg_pnj":{"id":"B6vI2gxyEe5pf7g8","value":"3d8","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_actual_pnj":{"id":"3CRGe021z6heUyKW","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_totales_pnj":{"id":"I7saN3A1Pc6tP2JP","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"salvaciones_pnj":{"id":"muaKYz2kmzsl5Cbp","value":"Fuerza, COnstitución","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"moral_pnj":{"id":"w9q5nM0h2aM1gAPs","value":"7","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"gloria_pnj":{"id":"GKgvhSguApjIemPx","value":"150","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"tesoro_pnj":{"id":"vWzdz8cpctB1J8AM","value":"Nada","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"notas_pnj":{"id":"1WHoLtjD4sE2zKVA","value":"3 abominaciones.\nUn replicante parece una persona que haya suplantado, hasta el último\ndetalle, incluyendo conocimientos y carácter. Sin embargo, si sufre al menos 1 punto de daño o se encuentra bajo una situación de intenso estrés, revelará su verdadera naturaleza: una criatura monstruosa e inhumana. Su cuerpo mutará en formas imposibles, tentáculos, garras y bocas monstruosas emergerán en los lugares más insospechados y el replicante las usará para defenderse.\n\nLa mera visión de esta transformación obliga a los que la presencian a superar una tarea sencilla de Coraje o quedar paralizados durante un asalto, mientras se recuperan de la impresión. En su forma verdadera, los replicantes son inmunes al daño de las armas: sólo la magia o el fuego pueden herirlos. Si un replicante logra escapar, se restablecerá rápidamente y volverá a su forma humana.","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false}},"citems":[{"id":"w9gK4Mpd1AMn5CPN","ikey":"","name":"Abominaciones","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Abominaciones","daño_pnj":{"value":"1d6"},"da_pnj":{"value":"d8"}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey":"gr_ataquespnj"}],"usetype":"PAS","ispermanent":false,"rechargable":false,"maxuses":1,"uses":1,"icon":"BOOK","selfdestruct":false,"mods":[],"disabledmods":[]}],"rolls":{},"biography":""},"ownership":{"default":0,"jZrpyZWDeO9ZrFIz":3},"prototypeToken":{"flags":{},"name":"Replicante","displayName":0,"width":1,"height":1,"lockRotation":false,"rotation":0,"actorLink":false,"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"randomImg":false,"alpha":1,"light":{"alpha":1,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"type":null,"reverse":false},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"texture":{"src":"worlds/tesoroygloria/resources/Recursos%20Compendium/Bestiario/icono_informes.png","tint":null,"scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"visionMode":"basic","color":null,"attenuation":0.1,"saturation":0,"contrast":0},"detectionModes":[]},"_stats":{"systemId":"sandbox","systemVersion":"0.14.4.4","coreVersion":"10.312","createdTime":null,"modifiedTime":1777448490363,"lastModifiedBy":"jZrpyZWDeO9ZrFIz"}}
{"_id":"WhwrZViuIEYrXzWM","name":"Lobbe","type":"character","img":"worlds/tesoroygloria/resources/Recursos%20Compendium/Bestiario/icono_impios.png","items":[],"effects":[],"folder":"TWnKxiRULMTzG8Ga","sort":500001,"flags":{"sbupdated":0,"ischeckingauto":false,"hasupdated":true,"scrolls":{"jZrpyZWDeO9ZrFIz":0},"lastupdatedBy":"jZrpyZWDeO9ZrFIz","activetab":0,"selectedtab":0,"haschanged":true,"sandbox":{"originalId":"WhwrZViuIEYrXzWM"}},"system":{"tabs":[],"istemplate":false,"gtemplate":"TyG_PNJ 1.0","sheets":["Default","TyG_PJ 1.0","TyG_PNJ 1.0"],"mod":"0","rollmode":"1d20","displayName":0,"tokenbar1":"attributes.","shieldstat":"","biovisible":true,"visitabs":3,"_html":"","backg":"","resizable":true,"setheight":600,"setwidth":650,"buildlog":"","selector":false,"attributes":{"tipo_pnj":{"id":"TPYqCw48wviNzZ5z","value":"Impío","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"vacia01":{"id":"V7x0LLDlex8CYwlq","value":"","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"numero_encuentro":{"id":"gbjg7FGebCEXoLCT","value":"1d3","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"numero_guarida":{"id":"LfO1EyAy2B6cWxrs","value":"1d3","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"reaccion":{"id":"xVWTk4TP21qu0C73","value":"Hostil","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"vel_pnj":{"id":"qNsaYmedjmMtwhnK","value":"12 m","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"ca_pnj":{"id":"cjj9fPKtXeZegxyg","value":5,"prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"max":null,"modified":false,"modmax":false},"dg_pnj":{"id":"B6vI2gxyEe5pf7g8","value":"4d8+4","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_actual_pnj":{"id":"3CRGe021z6heUyKW","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_totales_pnj":{"id":"I7saN3A1Pc6tP2JP","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"salvaciones_pnj":{"id":"muaKYz2kmzsl5Cbp","value":"Fuerza, Inteligencia, Sabiduría","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"moral_pnj":{"id":"w9q5nM0h2aM1gAPs","value":"6","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"gloria_pnj":{"id":"GKgvhSguApjIemPx","value":"300","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"tesoro_pnj":{"id":"vWzdz8cpctB1J8AM","value":"Monedas escaso - 2d4 x 10 mo\nGemas abundante - 2d20 gemas\nJoyas bastante - 1d4 joyas","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"notas_pnj":{"id":"1WHoLtjD4sE2zKVA","value":"El mordisco de una lobbe maldice a su víctima de tal manera que durante la siguientes 2d6 noches sufrirá de espantosas y horrendas pesadillas, que le impedirán descansar apropiadamente (penalizador de -2 a la recuperación). Al término de esos días, una pesadilla especialmente virulenta despertará a la víctima, que a continuación será desgarrada desde dentro por decenas de crías de lobbe, que la consumirán por entero para luego devorar todo lo que se encuentre a su alrededor (un enjambre de 1 DG y que provoca 1d4 de daño a todo el que ataque, impacto automático). Una vez no quede nada, comenzarán a consumirse entre sí, hasta que sólo quede una, gorda y abotargada, que se retirará a las sombras desde donde en 1d4 días emergerá convertida en nueva lobbe. Habitualmente, la lobbe ataca a su víctima, la muerde y huye de inmediato. Se puede eliminar la maldición de una lobbe con una invocación de Luz o Vida de nivel 2.","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false}},"citems":[{"id":"7JrGwdopsaxUCgKy","ikey":"","name":"Mordisco","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Mordisco","daño_pnj":{"value":"1d8"},"da_pnj":{"value":"d8"}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey":"gr_ataquespnj"}],"usetype":"PAS","ispermanent":false,"rechargable":false,"maxuses":1,"uses":1,"icon":"BOOK","selfdestruct":false,"mods":[],"disabledmods":[]}],"rolls":{},"biography":""},"ownership":{"default":0,"jZrpyZWDeO9ZrFIz":3},"prototypeToken":{"flags":{},"name":"Lobbe","displayName":0,"width":1,"height":1,"lockRotation":false,"rotation":0,"actorLink":false,"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"randomImg":false,"alpha":1,"light":{"alpha":1,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"type":null,"reverse":false},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"texture":{"src":"worlds/tesoroygloria/resources/Recursos%20Compendium/Bestiario/icono_impios.png","tint":null,"scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"visionMode":"basic","color":null,"attenuation":0.1,"saturation":0,"contrast":0},"detectionModes":[]},"_stats":{"systemId":"sandbox","systemVersion":"0.14.4.4","coreVersion":"10.312","createdTime":null,"modifiedTime":1777448489924,"lastModifiedBy":"jZrpyZWDeO9ZrFIz"}}
