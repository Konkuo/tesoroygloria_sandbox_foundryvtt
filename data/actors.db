{"_id":"ESloG6IKj3yDvy8M","name":"Sanjelo","type":"character","img":"worlds/tesoroygloria/resources/Recursos%20Compendium/Bestiario/icono_muertos.png","items":[],"effects":[],"folder":"1BJKQg70Nrgy1gQd","sort":700001,"flags":{"sbupdated":0,"ischeckingauto":false,"hasupdated":true,"scrolls":{"jZrpyZWDeO9ZrFIz":0},"lastupdatedBy":"jZrpyZWDeO9ZrFIz","activetab":0,"selectedtab":0,"haschanged":true,"sandbox":{"originalId":"ESloG6IKj3yDvy8M"}},"system":{"tabs":[],"istemplate":false,"gtemplate":"TyG_PNJ 1.0","sheets":["Default","TyG_PJ 1.0","TyG_PNJ 1.0"],"mod":"0","rollmode":"1d20","displayName":0,"tokenbar1":"attributes.","shieldstat":"","biovisible":true,"visitabs":3,"_html":"","backg":"","resizable":true,"setheight":600,"setwidth":650,"buildlog":"","selector":false,"attributes":{"tipo_pnj":{"id":"TPYqCw48wviNzZ5z","value":"Muerto","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"vacia01":{"id":"V7x0LLDlex8CYwlq","value":"","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"numero_encuentro":{"id":"gbjg7FGebCEXoLCT","value":"2d6","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"numero_guarida":{"id":"LfO1EyAy2B6cWxrs","value":"4d12","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"reaccion":{"id":"xVWTk4TP21qu0C73","value":"Hostil","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"vel_pnj":{"id":"qNsaYmedjmMtwhnK","value":"10 m","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"ca_pnj":{"id":"cjj9fPKtXeZegxyg","value":7,"prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"max":null,"modified":false,"modmax":false},"dg_pnj":{"id":"B6vI2gxyEe5pf7g8","value":"1d8","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_actual_pnj":{"id":"3CRGe021z6heUyKW","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_totales_pnj":{"id":"I7saN3A1Pc6tP2JP","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"salvaciones_pnj":{"id":"muaKYz2kmzsl5Cbp","value":"Destreza","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"moral_pnj":{"id":"w9q5nM0h2aM1gAPs","value":"7","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"gloria_pnj":{"id":"GKgvhSguApjIemPx","value":"30","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"tesoro_pnj":{"id":"vWzdz8cpctB1J8AM","value":"Monedas escaso - 2d4 x 10 mo\nRestos abundante - 1 resto útil (1-3/1d6)","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"notas_pnj":{"id":"1WHoLtjD4sE2zKVA","value":"Los sanjelos tienen gran cantidad de debilidades: la luz del Sol los destruye al instante, la sal les provoca un gran dolor, no pueden entrar en una residencia sin ser invitados (pero sí en lugares públicos, como una taberna), el símbolo de la Cruz los repele y les impide acercarse a menos de 3 metros, el olor del ajo o la visión del fuego los obligan a realizar una tirada de moral para no huir, no pueden cruzar corrientes de agua, durante el día caen en un profundo sopor del que no pueden despertar, incluso bajo tierra. No sé si me dejo algo. Por otra parte, con armas mortales sólo un golpe crítico podrá darles muerte (un golpe en la cabeza o el corazón, vaya).\n\nEl mordisco de un sanjelo inocula una peligrosa toxina que provoca el éxtasis en quien la recibe, que queda así indefenso ante la criatura. Esto funciona de forma similar al opio y otras drogas semejantes.","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false}},"citems":[{"id":"7JrGwdopsaxUCgKy","ikey":"","name":"Mordisco","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Mordisco","daño_pnj":{"value":"1d6"},"da_pnj":{"value":"d12"}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey":"gr_ataquespnj"}],"usetype":"PAS","ispermanent":false,"rechargable":false,"maxuses":1,"uses":1,"icon":"BOOK","selfdestruct":false,"mods":[],"disabledmods":[]}],"rolls":{},"biography":""},"ownership":{"default":0,"jZrpyZWDeO9ZrFIz":3},"prototypeToken":{"flags":{},"name":"Sanjelo","displayName":0,"width":1,"height":1,"lockRotation":false,"rotation":0,"actorLink":false,"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"randomImg":false,"alpha":1,"light":{"alpha":1,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"type":null,"reverse":false},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"texture":{"src":"worlds/tesoroygloria/resources/Recursos%20Compendium/Bestiario/icono_muertos.png","tint":null,"scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"visionMode":"basic","color":null,"attenuation":0.1,"saturation":0,"contrast":0},"detectionModes":[]},"_stats":{"systemId":"sandbox","systemVersion":"0.14.4.4","coreVersion":"10.312","createdTime":null,"modifiedTime":1777448490410,"lastModifiedBy":"jZrpyZWDeO9ZrFIz"}}
{"name":"Prueba","type":"character","img":"icons/svg/mystery-man.svg","system":{"tabs":[],"istemplate":false,"gtemplate":"TyG_PJ 1.0","sheets":["Default","TyG_PJ 1.0","TyG_PNJ 1.0"],"mod":0,"rollmode":"1d20","displayName":50,"tokenbar1":"attributes.attributes.null","shieldstat":"","biovisible":false,"visitabs":2,"_html":"<form class=\"{{cssClass}}\" autocomplete=\"off\" id=\"sheet\">\n    {{!-- Sheet Header --}}\n    <header class=\"sheet-header\">\n        <img class=\"profile-img\" src=\"{{actor.img}}\" title=\"{{actor.name}}\" data-edit=\"img\" height=\"100\" width=\"100\">\n        <div class=\"header-fields\">\n            <h1 class=\"charname\"><input name=\"name\" class=\"entityname\" type=\"text\" value=\"{{actor.name}}\" placeholder=\"Name\"></h1>\n            <div class=\"flexblock-left charsetup\">\n                <div class=\"col-1-2\">\n                    {{#if actor.system.istemplate}}\n                    {{else}}\n                    <div class=\"flexblock-left\">\n\n                        {{#advShow}}\n                        <a class=\"roll-mode boldtext\" title=\"Roll mode\"><i>{{actor.system.rollmode}}</i></a>\n                        {{/advShow}}\n\n                        {{#showRoller}}\n                        <a class=\"roll-free\" title=\"Show quick roller\"><i class=\"fas fa-dice-d20\"></i></a>\n                        {{/showRoller}}\n\n                        {{#if actor.system.selector}}\n                        <a class=\"mod-selector\" title=\"Select Options\"><i class=\"fas fa-exclamation-circle fa-2x\"></i></a>\n                        {{/if}}\n\n                        {{#rollMod}}\n                        <label class=\"label-mod\">MOD</label>\n                        <input class=\"input-mod\" type=\"number\" name=\"system.mod\" value=\"{{actor.system.mod}}\">\n                        {{/rollMod}}\n\n                    </div>\n                    {{/if}}\n                </div>\n\n                <div class=\"rightblock gmsetup\">\n                    {{#if actor.system.istemplate}}\n                    {{else}}\n                    {{#isGM}}\n                    <a class=\"sheet-reload\" title=\"Reload Template\"><i class=\"fas fa-arrow-alt-circle-down fa-2x\"></i></a>\n                    <select class=\"selectsheet\" name=\"system.gtemplate\" data-type=\"String\">\n                    </select>\n                    {{/isGM}}\n                    {{/if}}\n                    {{#isGM}}\n\n\n                    <label class=\"rightblock-element\">Template</label>\n                    <input class=\"check-istemplate\" name=\"system.istemplate\" id=\"check-istemplate\" type=\"checkbox\" {{checked actor.system.istemplate}}=\"\">\n\n\n                    {{/isGM}}\n\n                    {{#if actor.system.istemplate}}\n                    <label class=\"rightblock-element-tag\">Rebuild Sheet</label>\n                    <a class=\"rightblock-element item-refresh\" title=\"Rebuild Sheet\"><i class=\"fas fa-sync\"></i></a>\n                    {{/if}}\n                </div>\n            </div>\n        </div>\n    </header>\n\n    {{!-- Sheet Tab Navigation --}}\n    <div class=\"atabs\">\n        <a class=\"tab-prev\" id=\"tab-prev\"><i class=\"leftarrow\"></i></a>\n        <nav class=\"sheet-tabs tabs\" data-group=\"primary\" id=\"tabs\" tabs=\"2\">\n\n            <a class=\"item tab-button player-tab desc-tab\" data-tab=\"description\" id=\"tab-0\">Bio</a>          \n            <a class=\"item tab-button player-tab\" id=\"tab-1\" data-tab=\"hoja01\">Primera página</a><a class=\"item tab-button player-tab\" id=\"tab-2\" data-tab=\"hoja02\">Segunda página</a><a style=\"display: none\" id=\"tab-last\"></a>\n            {{#isGM}}\n            {{#if actor.system.istemplate}}\n            <a class=\"item tab-button\" data-tab=\"token\" id=\"tab-token\">Config</a>\n            <a class=\"item tab-button\" data-tab=\"config\" id=\"tab-tabs\">Tabs</a>\n            {{/if}}\n            <a class=\"item tab-button\" data-tab=\"citems\" id=\"tab-citems\">cItems</a>\n            {{/isGM}}\n\n        </nav>\n        <a class=\"tab-next\" id=\"tab-next\"><i class=\"rightarrow\"></i></a>\n    </div>\n\n    {{!-- Sheet Body --}}\n    <section class=\"sheet-body\" id=\"sheet-body\">\n\n        {{!-- Biography Tab --}}\n        <div class=\"tab biography active scrollable\" data-group=\"primary\" data-tab=\"description\">                        \n            {{editor\n                enrichedBiography\n                target=\"system.biography\"\n                button=true\n                editable=editable\n            }}\n            \n        </div>\n\n        {{#if actor.system.istemplate}}\n        {{!-- SheetTabs Tab --}}\n        <div class=\"tab properties\" data-group=\"primary\" data-tab=\"config\">\n            <ol class=\"properties-list\">\n                {{#each actor.system.tabs as |tab id|}}\n                <li class=\"property flexrow\" data-item-id=\"{{id}}\">\n                    <img class=\"sb-citem-table-icon\" src=\"{{{sb_item_icon tab.id}}}\">\n                    <label class=\"property-name  sb-sub-item-label\">{{tab.name}}</label>\n                    <div class=\"property-row\">\n                        <a class=\"property-controls item-top\" title=\"Top Item\"><i class=\"fas fa-arrow-alt-circle-up\"></i></a>\n                        <a class=\"property-controls item-bottom\" title=\"Bottom Item\"><i class=\"fas fa-arrow-alt-circle-down\"></i></a>\n                        <a class=\"property-control item-edit\" title=\"Edit Tab\"><i class=\"fas fa-edit\"></i></a>\n                        <a class=\"property-control item-delete\" title=\"Delete Tab\"><i class=\"fas fa-trash\"></i></a>\n                    </div>\n                </li>\n                {{/each}}\n            </ol>\n        </div>\n        {{!-- Config Tab --}}\n        <div class=\"tab token scrollable\" data-group=\"primary\" data-tab=\"token\">\n            <div class=\"flexblock\">\n                <div class=\"col-1-2\">\n                    <div class=\"new-row\">\n                        <div class=\"panelheader\">\n                            <label class=\"label-medlarge\">TOKEN OPTIONS</label>\n                        </div>\n                    </div>\n                    <div class=\"new-row\">\n                        <div class=\"flexblock-left\">\n                            <label class=\"label-medlarge\">Bar 1</label>\n                            <input class=\"token-bar1\" type=\"text\" name=\"system.tokenbar1\" value=\"{{actor.system.tokenbar1}}\" tkvalue=\"attributes.null\">\n                        </div>\n                    </div>\n                    <div class=\"new-row\">\n                        <div class=\"flexblock-left\">\n                            <label class=\"label-medlarge\">Shield Stat</label>\n                            <input class=\"token-shieldstat\" type=\"text\" name=\"system.shieldstat\" value=\"{{actor.system.shieldstat}}\" tkvalue=\"\">\n                        </div>\n                    </div>\n                    <div class=\"new-row\">\n                        <div class=\"flexblock-left\">\n                            <label class=\"label-medlarge\">Display Name</label>\n                            <select class=\"token-displayName\" name=\"system.displayName\" data-type=\"String\" tkvalue=\"ALWAYS\">\n                                {{#select actor.system.displayName}}\n                                <option value=\"NONE\">NONE</option>\n                                <option value=\"CONTROL\">CONTROL</option>\n                                <option value=\"OWNER_HOVER\">OWNER HOVER</option>\n                                <option value=\"HOVER\">HOVER</option>\n                                <option value=\"OWNER\">OWNER</option>\n                                <option value=\"ALWAYS\">ALWAYS</option>\n                                {{/select}}\n                            </select>\n                        </div>\n                    </div>\n\n                    <div class=\"new-row\">\n                        <div class=\"panelheader\">\n                            <label class=\"label-medlarge\">TAB OPTIONS</label>\n                        </div>\n\n                        <div class=\"flexblock-left\">\n                            <label class=\"label-medlarge\">BIO Tab Visible</label>\n                            <input class=\"check-biovisible\" name=\"system.biovisible\" id=\"check-biovisible\" type=\"checkbox\" biovisible=\"false\" {{checked=\"\" actor.system.biovisible}}=\"\">\n                        </div>\n\n                        <div class=\"flexblock-left\">\n                            <label class=\"label-medlarge\">Max visible Tabs</label>\n                            <select class=\"token-visitabs\" name=\"system.visitabs\" data-type=\"String\" visitabs=\"2\">\n                                {{#select actor.system.visitabs}}\n                                <option value=\"2\">2</option>\n                                <option value=\"3\">3</option>\n                                <option value=\"4\">4</option>\n                                <option value=\"5\">5</option>\n                                {{/select}}\n                            </select>\n                        </div>\n                    </div>\n\n                </div>\n                <div class=\"col-1-2\">\n                    <div class=\"new-row\">\n                        <div class=\"panelheader\">\n                            <label class=\"label-medlarge\">SHEET STYLES</label>\n                        </div>\n                    </div>\n                    <div class=\"new-row\">\n                        <div class=\"flexblock-left\">\n                            <label class=\"label-medlarge\">Background</label>\n                            <input class=\"gsheet-backg\" type=\"text\" name=\"system.backg\" value=\"{{actor.system.backg}}\">\n                            <a class=\"gsheet-backg-filepicker\" title=\"Browse Image\"><i class=\"fas fa-file-upload fa-2x\"></i></a>\n                        </div>\n                    </div>\n                    <div class=\"new-row\">\n                        <div class=\"flexblock-left\">\n                            <label class=\"label-medlarge\">Height</label>\n                            <input class=\"gsheet-setheight\" type=\"text\" name=\"system.setheight\" value=\"{{actor.system.setheight}}\">\n                        </div>\n                    </div>\n                    <div class=\"new-row\">\n                        <div class=\"flexblock-left\">\n                            <label class=\"label-medlarge\">Width</label>\n                            <input class=\"gsheet-setheight\" type=\"text\" name=\"system.setwidth\" value=\"{{actor.system.setwidth}}\">\n                        </div>\n                    </div>\n                    <div class=\"new-row\">\n                        <div class=\"flexblock-left\">\n                            <label class=\"label-medlarge\">Resizable</label>\n                            <input class=\"check-resizable\" name=\"system.resizable\" id=\"check-resizable\" type=\"checkbox\" resizable=\"false\" {{checked=\"\" actor.system.resizable}}=\"\">\n                        </div>\n                    </div>\n\n                </div>\n\n            </div>\n            <div class=\"col-1-1\">\n                <div class=\"new-row\">\n                    <div class=\"panelheader\">\n                        <label class=\"label-medlarge\">ERROR LOG (BETA)</label>\n                    </div>\n                </div>\n                <div class=\"new-row\">\n                    <textarea class=\"texteditor-large input-disabled\" name=\"system.buildlog\">{{actor.system.buildlog}}\n                    </textarea>\n                </div>\n            </div>\n        </div>\n        {{/if}}\n\n        {{!-- cItems Tab --}}\n        <div class=\"tab citems scrollable\" data-group=\"primary\" data-tab=\"citems\">\n            <ol class=\"properties-list\" id=\"citems-tab\">\n                {{#each actor.system.citems as |citem cid|}}\n                <li class=\"property flexrow\" data-item-id=\"{{cid}}\">\n                  <img class=\"sb-citem-table-icon\" src=\"{{{sb_item_icon citem.id}}}\">\n                    <label class=\"property-name sb-null  sb-sub-item-label\">{{citem.name}}</label>\n                    <div class=\"property-row\">\n                        <a class=\"property-control citem-edit\" title=\"Edit cItem\"><i class=\"fas fa-edit\"></i></a>                        \n                        <a class=\"property-control citem-delete\" citemid=\"{{citem.id}}\" cikey=\"{{citem.ciKey}}\" title=\"Remove cItem\"><i class=\"fas fa-trash\"></i></a>\n                        {{#ifNotEmpty citem.addedBy}}\n                           <i title=\"Added automatically by {{cItemAddedBy citem.addedBy}}\" class=\"fas fa-circle-info\"></i>\n                        {{/ifNotEmpty}}\n                    </div>\n                </li>\n                {{/each}}\n            </ol>\n        </div>\n\n\n\n    <div class=\"tab scrollable hoja01_tab\" id=\"hoja01_Def\" data-group=\"primary\" data-tab=\"hoja01\"><div class=\"new-column sbbody\" id=\"hoja01Body\"><div class=\"new-block\" id=\"hoja01row10\"><div id=\"informacion_basicamulti\" class=\"multi-1-1-col\"><div class=\"panelheader \">INFORMACIÓN BÁSICA</div><div class=\"new-block\" id=\"informacion_basicamultirow1\"><div class=\"multi-1-3 informacion_basica_panel01_container\"><div class=\"new-row informacion_basica_panel01\"><div class=\"flexblock-left informacion_basica_panel01_row\"><h3 class=\" label-medlarge nombre_label boldtext\" id=\"nombre\" attid=\"7Nkv2N1NMPwoo3il\">Nombre:</h3><input name=\"system.attributes.nombre.value\" value=\"{{actor.system.attributes.nombre.value}}\" title=\"\" type=\"text\" class=\"input-fr