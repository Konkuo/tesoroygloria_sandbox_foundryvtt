8+4","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_actual_pnj":{"id":"3CRGe021z6heUyKW","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_totales_pnj":{"id":"I7saN3A1Pc6tP2JP","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"salvaciones_pnj":{"id":"muaKYz2kmzsl5Cbp","value":"Fuerza, Constitución","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"moral_pnj":{"id":"w9q5nM0h2aM1gAPs","value":"7","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"gloria_pnj":{"id":"GKgvhSguApjIemPx","value":"500","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"tesoro_pnj":{"id":"vWzdz8cpctB1J8AM","value":"Monedas bastante - 2d6 x 50 mo\nGemas escaso - 1d10 gemas\nJoyas escaso - 1 joya","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"notas_pnj":{"id":"1WHoLtjD4sE2zKVA","value":"Los venragos pueden hipnotizar a sus víctimas. Basta con que les miren a los ojos y fallen una tarea difícil de Concentración para caer bajo su embrujo. En este estado de trance, caminarán al encuentro del venrago sin ningún miedo y arrojando sus armas al suelo al tiempo que comienzan a desvestirse, despertando una vez se encuentren entre sus monstruosos brazos, ya sin posibilidad de huir. El venrago sólo puede hipnotizar a una persona cada vez. Es posible interrumpir el encantamiento si se interrumpe la línea de visión o el venrago sufre un golpe crítico.","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false}},"citems":[{"id":"7JrGwdopsaxUCgKy","ikey":"","name":"