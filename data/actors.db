ocked":false,"modified":false,"modmax":false},"gloria_pnj":{"id":"GKgvhSguApjIemPx","value":"900","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"tesoro_pnj":{"id":"vWzdz8cpctB1J8AM","value":"Monedas abundante - 2d8 x 100 mo\nGemas bastante - 1d20 gemas\nJoyas abundante - 1d6 joyas\nObjetos preciosos escaso - 1d4 obj.","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"notas_pnj":{"id":"1WHoLtjD4sE2zKVA","value":"2 garras y mordisco o aliento de fuego (leer descripción abajo para daño).\n\nEl aliento de fuego ocupa un cono de hasta 10 metros, y un personaje podría tratar de apartarse de su camino con una tarea difícil de Reflejos, aunque la presencia de cobertura cercana podría facilitar la\ntarea. Se recarga con 5-6 en 1d6 (tira una vez por asalto) y provoca daño igual a la mitad de la salud actual del draco. Si, por ejemplo, el draco tiene 40 PG, provocará 20 puntos de daño. Si el draco sufre luego 12 puntos de daño, quedándose en 28 PG, su aliento provocará 14 puntos de daño. Los dracos reciben la mitad de daño por fuego.","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false}},"citems":[{"id":"yye6Xazsoe7aoj5D","ikey":"","name":"Aliento de fuego","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Aliento de fuego","daño_pnj":{"value":"0"},"da_pnj":{"value":"1"}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey":"gr_ataquespnj"}],"usetype":"PAS","ispermanent":false,"rechargable":false,"maxuses":1,"uses":1,"icon":"BOOK","selfdestruct":false,"mods":[],"disabledmods":[]},{"id":"pyMvW4XVS0bTIABe","ikey":"","name":"Garra","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Garra","daño_pnj":{"value":"1d6"},"da_pnj":{"value":"d6"}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey"