 quedará paralizado por el terror durante 1d4 asaltos. Si por el contrario consigue superar la tirada, tan sólo sufrirá 1d4 puntos de daño por frío.\n\nUna izela puede invocar el dominio Oscuridad a voluntad, como si tuviera puntos de devoción inagotables.","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false,"maxset":false,"maxexec":false}},"citems":[{"id":"Ewml3fHZl9Lz9da6","ikey":"","name":"Toque","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Toque","daño_pnj":{"value":"0"},"da_pnj":{"value":"d6"},"boton_da_pnj":{"value":""},"boton_daño_pnj":{"value":""}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey":"gr_ataquespnj"}],"usetype":"PAS","ispermanent":false,"rechargable":false,"maxuses":1,"uses":1,"icon":"BOOK","selfdestruct":false,"mods":[],"disabledmods":[],"ciKey":"Ewml3fHZl9Lz9da6"}],"rolls":{},"biography":""},"ownership":{"default":0,"jZrpyZWDeO9ZrFIz":3},"prototypeToken":{"flags":{},"name":"Incorpóreo espectro (Copy)","displayName":0,"width":1,"height":1,"lockRotation":false,"rotation":0,"actorLink":false,"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"randomImg":false,"alpha":1,"light":{"alpha":1,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"type":null,"reverse":false},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"texture":{"src":"worlds/tesoroygloria/resources/Recursos%20Compendium/Bestiario/icono_muertos.png","tint":null,"scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"visionMode":"basic","color":null,"attenuation":0.1,"saturation":0,"contrast":0},"detectionModes":[]},"_stats":{"systemId":"sandbox","systemVersion":"0.14.4.4","coreVersion":"10.312","createdTime":null,"modifiedTime":1777448489680,"lastModifiedBy":"jZrpyZWD