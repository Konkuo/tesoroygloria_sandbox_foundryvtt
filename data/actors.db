sabledmods":[]}],"rolls":{},"biography":"<table style=\"height: 96px; width: 99.0228%;\" border=\"1\">\n<tbody>\n<tr style=\"height: 16px;\">\n<td style=\"height: 16px; width: 15.4605%; text-align: center;\"><strong>Nivel</strong></td>\n<td style=\"height: 16px; width: 8.71711%; text-align: center;\"><strong>CA</strong></td>\n<td style=\"height: 16px; width: 9.21053%; text-align: center;\"><strong>DG</strong></td>\n<td style=\"height: 16px; width: 11.0197%; text-align: center;\"><strong>DA</strong></td>\n<td style=\"height: 16px; width: 14.9671%; text-align: center;\"><strong>Da&ntilde;o</strong></td>\n<td style=\"height: 16px; width: 39.1447%; text-align: center;\"><strong>Pericias</strong></td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"height: 16px; width: 15.4605%; text-align: center;\">1</td>\n<td style=\"height: 16px; width: 8.71711%; text-align: center;\">5</td>\n<td style=\"height: 16px; width: 9.21053%; text-align: center;\">2</td>\n<td style=\"height: 16px; width: 11.0197%; text-align: center;\">d12</td>\n<td style=\"height: 16px; width: 14.9671%; text-align: center;\">1d8</td>\n<td style=\"height: 16px; width: 39.1447%; text-align: center;\">Religi&oacute;n, Coraje</td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"height: 16px; width: 15.4605%; text-align: center;\">2</td>\n<td style=\"height: 16px; width: 8.71711%; text-align: center;\">5</td>\n<td style=\"height: 16px; width: 9.21053%; text-align: center;\">3</td>\n<td style=\"height: 16px; width: 11.0197%; text-align: center;\">d12</td>\n<td style=\"height: 16px; width: 14.9671%; text-align: center;\">1d8</td>\n<td style=\"height: 16px; width: 39.1447%; text-align: center;\">Diplomacia</td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"height: 16px; width: 15.4605%; text-align: center;\">3</td>\n<td style=\"height: 16px; width: 8.71711%; text-align: center;\">4</td>\n<td style=\"height: 16px; width: 9.21053%; text-align: center;\">4</td>\n<td style=\"height: 16px; width: 11.0197%; text-