d8+10","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_actual_pnj":{"id":"3CRGe021z6heUyKW","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"pg_totales_pnj":{"id":"I7saN3A1Pc6tP2JP","value":"0","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"salvaciones_pnj":{"id":"muaKYz2kmzsl5Cbp","value":"Fuerza, Constitución, Inteligencia, Sabiduría","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"moral_pnj":{"id":"w9q5nM0h2aM1gAPs","value":"8","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"gloria_pnj":{"id":"GKgvhSguApjIemPx","value":"700","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"tesoro_pnj":{"id":"vWzdz8cpctB1J8AM","value":"Monedas escaso - 2d4 x 10 mo\nGemas bastante - 1d20 gemas\nJoyas escaso - 1 joya","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false},"notas_pnj":{"id":"1WHoLtjD4sE2zKVA","value":"Encuentro: +2d6 lobos.\nLos huargos son enormes y astutos, de inteligencia igual (si no superior)\na la humana. Son capaces de invocar el dominio de Matanza con una reserva de devoción de 2d6 puntos, y al morder a alguien pueden gastar 2 puntos de esa reserva para maldecirlo, haciendo que se transforme en un gizotso. Además, pueden esclavizar a lobos y perros a voluntad con su magia. Al morir el cuerpo de un huargo, si no fue golpeado con acero salado o daño sagrado de algún tipo semejante, el demonio podrá poseer el cuerpo de un lobo cercano. Tras esto, normalmente huirá, para regresar en 2d4 días convertido de nuevo en un huargo completo. Además de los lobos de los que se rodean, hay 1-2 en 1d6 posibilidades de que los acompañe una tribu de trasgos, que adorarán al huargo como si de su dios se tratara. También hay 1 en 1d6 posibilidades de que el huargo sea además capaz de conjurar, en cuyo caso tendrá DH d10 y UP 4, llevando normalmente preparados conjuros de Orden, Hechizar e Invocación.","prev":"","isset":false,"default":false,"autoadd":0,"maxadd":0,"maxblocked":false,"modified":false,"modmax":false}},"citems":[{"id":"7JrGwdopsaxUCgKy","ikey":"","name":"Mordisco","number":1,"isactive":false,"isreset":true,"attributes":{"name":"Mordisco","daño_pnj":{"value":"2d6"},"da_pnj":{"value":"d6"}},"rolls":{},"lastroll":0,"groups":[{"id":"oFoGiVdMANbd93P5","name":"Ataques PNJ","ikey":"gr_ataquespnj"}],"usetype":"PAS","ispermanent":false,"rechargable":false,"maxuses":1,"uses":1,"icon":"BOOK","selfdestruct":false,"mods":[],"disabledmods":[]}],"rolls":{},"biography":""},"ownership":{"default":0,"jZrpyZWDeO9ZrFIz":3},"prototypeToken":{"flags":{},"name":"Huargo","displayName":0,"width":1,"height":1,"lockRotation":false,"rotation":0,"actorLink":false,"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"randomImg":false,"alpha":1,"light":{"alpha":1,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"type":null,"reverse":false},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"texture":{"src":"worlds/tesoroygloria/resources/Recursos%20Compendium/Bestiario/icono_impios.png","tint":null,"scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"visionMode":"basic","color":null,"attenuation":0.1,"saturation":0,"contrast":0},"detectionModes":[]},"_stats":{"systemId":"sandbox","systemVersion":"0.14.4.4","coreVersion":"10.312","createdTime":null,"modifiedTime":1777448489590,"lastModifiedBy":"jZrpyZWDeO9ZrFIz"}}
